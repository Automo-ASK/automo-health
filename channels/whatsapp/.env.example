# whatsapp-service

PORT=3001

# Evolution API (docker). Key must match EVOLUTION_API_KEY in the root .env.
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=change-me-automo-evolution-key
EVOLUTION_INSTANCE=automo

# Where Evolution (inside docker) should POST webhooks. From a container the
# host is reachable at host.docker.internal on Windows/Mac.
PUBLIC_WEBHOOK_URL=http://host.docker.internal:3001/webhook/evolution

# Booking backend (Koded's stub on day 1; the real FastAPI backend later).
BACKEND_URL=http://localhost:3002

# AI conversation service (Adam's Gemini service, mounted in the backend).
# Set to the backend base URL to use it live; the client appends /api/v1/ai/interpret.
# Empty = use the built-in local stub client (same response shape, offline).
#   e.g. AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_URL=

# How many recent conversation turns to send to the AI as context.
AI_MAX_HISTORY_TURNS=10
