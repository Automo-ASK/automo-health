# --- Application ---
APP_NAME="Automo Health"
ENVIRONMENT="development"
DEBUG=true

# --- Database ---
# Format: postgresql+psycopg2://user:password@host:port/dbname
DATABASE_URL="postgresql+psycopg2://automo:automo@localhost:5432/automo_health"

# --- Celery / Redis ---
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/1"

# --- Booking / Slots ---
# How long a held slot stays reserved before it auto-expires (seconds).
SLOT_HOLD_TTL_SECONDS=600
# How long a booking can remain pending_payment before it auto-expires (seconds).
BOOKING_PAYMENT_TTL_SECONDS=900

# --- Payments ---
# Active provider for virtual accounts / links: "paystack" or "squad".
PAYMENT_PROVIDER="paystack"
# Currency ISO code used when initializing transactions.
DEFAULT_CURRENCY="NGN"

# --- Paystack ---
PAYSTACK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxx"
PAYSTACK_PUBLIC_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxx"
PAYSTACK_BASE_URL="https://api.paystack.co"
# Public URL Paystack redirects the customer to after payment.
PAYSTACK_CALLBACK_URL="http://localhost:8000/api/v1/payments/callback"
# Bank used when provisioning a dedicated virtual account (test: wema-bank / titan-paystack).
PAYSTACK_DVA_PREFERRED_BANK="test-bank"

# --- Notifications ---
# Optional outbound webhook that receives notification events (booking.confirmed, etc.) as JSON.
NOTIFICATIONS_WEBHOOK_URL=""
