# ---------------------------------------------------------------------------
# Automo Health - root env (used by docker-compose for the Evolution API stack)
# Copy to .env:  cp .env.example .env
# ---------------------------------------------------------------------------

# Evolution API docker image tag. Pin it; do not float on :latest.
EVOLUTION_VERSION=v2.1.1

# Public URL Evolution advertises for itself (QR pairing, media links).
EVOLUTION_SERVER_URL=http://localhost:8080

# Master API key for Evolution. CHANGE THIS. The whatsapp-service uses the same value.
EVOLUTION_API_KEY=change-me-automo-evolution-key

# WhatsApp Web version pinned to avoid Baileys connection bugs.
# Provided by Quadri - keep this exact value unless a newer known-good build is verified.
WA_WEB_VERSION=2.3000.1041645497
